---
Checks: >
  bugprone-*,
  cert-*,
  readability-*,
  performance-*,
  portability-*,
  misc-const-correctness,
  -bugprone-easily-swappable-parameters,
  -bugprone-reserved-identifier,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -cert-err33-c,
  -readability-avoid-const-params-in-decls,
  -readability-function-cognitive-complexity,
  -readability-identifier-naming,
  -readability-magic-numbers,
  -readability-uppercase-literal-suffix,
  -readability-identifier-length,
  -clang-diagnostic-declaration-after-statement,
  -clang-diagnostic-documentation,
  -clang-diagnostic-missing-noreturn,
  -clang-diagnostic-padded,
  -performance-no-int-to-ptr,
  -clang-diagnostic-unsafe-buffer-usage,
  -readability-isolate-declaration
FormatStyle: file
HeaderFilterRegex: '.*(app|modules|utils|bsp)/.*\.(h|hpp)'
WarningsAsErrors: '*'
CheckOptions:
  - key: readability-braces-around-statements.ShortStatementLines
    value: '0'
  - key: readability-simplify-boolean-expr.ChainedConditionalAssignment
    value: '0'
  - key: readability-simplify-boolean-expr.ChainedConditionalReturn
    value: '0'
  - key: bugprone-signed-char-misuse.CharTypedefsToIgnore
    value: 'uint8_t'
