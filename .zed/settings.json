{
  "lsp": {
    "clangd": {
      "binary": {
        "arguments": [
          "--header-insertion=never",
          "--background-index",
          "--clang-tidy",
          "-j=4",
          "--pch-storage=memory",
          "--function-arg-placeholders=false",
          "--compile-commands-dir=build",
          "--query-driver=E:/RM/tool-chains/arm-gnu-toolchain/bin/arm-none-eabi-gcc.exe",
        ],
      },
    },
  },
  "languages": {
    "C": {
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
    "C++": {
      "formatter": {
        "external": {
          "command": "clang-format",
          "arguments": ["--style=file", "--assume-filename={buffer_path}"],
        },
      },
      "format_on_save": "on",
    },
  },
}
