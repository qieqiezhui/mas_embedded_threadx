{
    "cmake.configureOnOpen": false,
    "cmake.automaticReconfigure": false,
    "cmake.configureOnEdit": false,
    "cortex-debug.armToolchainPath": "E:/RM/tool-chains/arm-gnu-toolchain/bin",  // ARM 工具链路径,自己解压的路径
    "cortex-debug.JLinkGDBServerPath": "D:/jlink/JLink/JLinkGDBServer.exe",  // JLink GDB Server 路径
    // 是否检查插件冲突
    "clangd.detectExtensionConflicts": true,
    "clangd.arguments": [
        // 禁用头文件自动补全
        "--header-insertion=never",
        // 在后台自动分析文件(基于 complie_commands)
        "--background-index",
        // 启用 Clang-Tidy 以提供「静态检查」
        "--clang-tidy",
        // 同时开启的任务数量
        "-j=4",
        // pch优化的位置(memory 或 disk，选择memory会增加内存开销，但会提升性能) 推荐在板子上使用disk
        "--pch-storage=memory",
        // 启用这项时，补全函数时，将会给参数提供占位符，键入后按 Tab 可以切换到下一占位符，乃至函数末
        "--function-arg-placeholders=false",
        // compelie_commands.json 文件的目录位置
        "--compile-commands-dir=build",
        "--query-driver=E:/RM/tool-chains/arm-gnu-toolchain/bin/arm-none-eabi-gcc.exe"  // ARM 工具链路径,自己解压的路径，到arm-none-eabi-gcc.exe即可
    ],
}

